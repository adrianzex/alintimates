{
  "compilerOptions": {
    "allowJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./*"],
      "@/components/ui/*": ["./*"],
      "@/context/*": ["./*"],
      "@/data/*": ["./*"],
      "@/assets/*": ["./*"],
      "@/hooks/*": ["./*"],
      "@/lib/*": ["./*"]
    },
    "skipLibCheck": true,
    "strictNullChecks": false
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
